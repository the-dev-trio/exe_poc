<Window x:Class="InventoryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryApp.ViewModels"
        Title="{Binding ShopName, StringFormat='{}{0} — Jewellery Manager'}"
        Height="720" Width="1280" MinWidth="1100" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource BodyFont}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowSalesCommand}" />
    </Window.InputBindings>

    <!--
        ROOT: 2-column layout
        Col 0 = full-height Sidebar (260 px)
        Col 1 = Header + Content stacked in a nested Grid
    -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════════════
             COLUMN 0 — SIDEBAR  (full height, Navy Blue background)
             ═══════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource SidebarDividerBrush}"
                BorderThickness="0,0,1,0">

            <DockPanel LastChildFill="False">

                <!-- Brand / Logo area -->
                <StackPanel DockPanel.Dock="Top" Margin="16,22,16,18">
                    <TextBlock Text="{Binding ShopName}"
                               FontSize="18" Style="{StaticResource HeadingText}"
                               Foreground="{StaticResource GoldBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Jewellery Manager"
                               FontSize="10" Foreground="{StaticResource SidebarTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Primary nav -->
                <StackPanel DockPanel.Dock="Top" Margin="10,0,10,0">
                    <Button Content="🏠  Dashboard"
                            Style="{Binding DashboardNavStyle,  Mode=OneWay}"
                            Command="{Binding ShowDashboardCommand}" />
                    <Button Content="💰  Daily Rates"
                            Style="{Binding DailyRatesNavStyle, Mode=OneWay}"
                            Command="{Binding ShowDailyRatesCommand}" />
                    <Button Content="🛒  POS / Sales  [F1]"
                            Style="{Binding SalesNavStyle,      Mode=OneWay}"
                            Command="{Binding ShowSalesCommand}" />
                    <Button Content="📦  Inventory"
                            Style="{Binding InventoryNavStyle,  Mode=OneWay}"
                            Command="{Binding ShowInventoryCommand}" />
                    <Button Content="🚚  Purchases"
                            Style="{Binding PurchasesNavStyle,  Mode=OneWay}"
                            Command="{Binding ShowPurchasesCommand}" />
                    <Button Content="👤  Customers"
                            Style="{Binding CustomersNavStyle,  Mode=OneWay}"
                            Command="{Binding ShowCustomersCommand}" />
                    <Button Content="📊  Reports"
                            Style="{Binding ReportsNavStyle,    Mode=OneWay}"
                            Command="{Binding ShowReportsCommand}" />
                </StackPanel>

                <!-- Divider -->
                <Border DockPanel.Dock="Top" Height="1" Background="#1e2d5a" Margin="16,14,16,6"/>

                <!-- Settings at bottom of top section -->
                <StackPanel DockPanel.Dock="Top" Margin="10,0,10,0">
                    <Button Content="⚙️  Settings"
                            Style="{Binding SettingsNavStyle, Mode=OneWay}"
                            Command="{Binding ShowSettingsCommand}" />
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════
             COLUMN 1 — Nested Grid: Header (row 0) + Content (row 1)
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#ffffff"
                    BorderBrush="#e2e8f0"
                    BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Page title (active nav name) -->
                    <TextBlock Grid.Column="0"
                               Text="{Binding CurrentPageTitle}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center"/>

                    <!-- Right: DateTime + Backup -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentDateTime}"
                                   FontSize="13" Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,20,0" VerticalAlignment="Center"/>
                        <Button Content="💾  Backup Now"
                                Command="{Binding BackupNowCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main content area -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding CurrentView}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
