<Window x:Class="InventoryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryApp.ViewModels"
        Title="Reddy Jewellery Manager" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        FontFamily="{StaticResource BodyFont}">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowSalesCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ TOP HEADER ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#ffffff" BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar toggle -->
                <Button Grid.Column="0" Content="☰" Width="36" Height="36" Margin="0,0,12,0"
                        Command="{Binding ToggleSidebarCommand}"
                        Background="Transparent" Foreground="#374151" BorderThickness="0"
                        FontSize="18" Cursor="Hand" VerticalAlignment="Center"/>

                <!-- Right: DateTime + Backup -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="💾  Backup Now" Command="{Binding BackupNowCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource SidebarDividerBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="10,18,10,0">
                <!-- Brand — bound to ShopName setting -->
                <TextBlock Text="{Binding ShopName}" FontSize="18" Style="{StaticResource HeadingText}" Foreground="{StaticResource GoldBrush}" Margin="8,0,8,2"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="Jewellery Manager" FontSize="10" Foreground="{StaticResource SidebarTextBrush}" Margin="8,0,8,16"/>

                <Button Content="🏠  Dashboard"
                        Style="{Binding DashboardNavStyle, Mode=OneWay}"
                        Command="{Binding ShowDashboardCommand}" />
                <Button Content="💰  Daily Rates"
                        Style="{Binding DailyRatesNavStyle, Mode=OneWay}"
                        Command="{Binding ShowDailyRatesCommand}" />
                <Button Content="🛒  POS / Sales  [F1]"
                        Style="{Binding SalesNavStyle, Mode=OneWay}"
                        Command="{Binding ShowSalesCommand}" />
                <Button Content="📦  Inventory"
                        Style="{Binding InventoryNavStyle, Mode=OneWay}"
                        Command="{Binding ShowInventoryCommand}" />
                <Button Content="🚚  Purchases"
                        Style="{Binding PurchasesNavStyle, Mode=OneWay}"
                        Command="{Binding ShowPurchasesCommand}" />

                <!-- Divider -->
                <Border Height="1" Background="#1e2d5a" Margin="8,12,8,8"/>

                <Button Content="⚙️  Settings"
                        Style="{Binding SettingsNavStyle, Mode=OneWay}"
                        Command="{Binding ShowSettingsCommand}" />
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ContentControl Content="{Binding CurrentView}" />
        </ScrollViewer>
    </Grid>
</Window>
