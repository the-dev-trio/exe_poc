<Window x:Class="InventoryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:InventoryApp.ViewModels"
        Title="Reddy Jewellery Manager" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f1e">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F1" Command="{Binding ShowSalesCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding SidebarWidth, Mode=OneWay}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══ TOP HEADER ════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#1a1a2e" BorderBrush="#2a2a3e" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Sidebar toggle -->
                <Button Grid.Column="0" Content="☰" Width="36" Height="36" Margin="0,0,12,0"
                        Command="{Binding ToggleSidebarCommand}"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        FontSize="18" Cursor="Hand" VerticalAlignment="Center"/>

                <!-- Brand name -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ShopName}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Jewellery Management System" FontSize="11" Foreground="#6b7280"/>
                </StackPanel>

                <!-- Spacer -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateTime}" FontSize="13" Foreground="#9ca3af" Margin="0,0,20,0" VerticalAlignment="Center"/>
                    <Button Content="💾 Backup Now" Command="{Binding BackupNowCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR ═══════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0" Background="#1a1a2e" BorderBrush="#2a2a3e" BorderThickness="0,0,1,0">
            <StackPanel Margin="8,16,8,0">
                <Button Content="📊  Dashboard"
                        Style="{Binding DashboardNavStyle, Mode=OneWay}"
                        Command="{Binding ShowDashboardCommand}" />
                <Button Content="🛒  POS / Sales  [F1]"
                        Style="{Binding SalesNavStyle, Mode=OneWay}"
                        Command="{Binding ShowSalesCommand}" />
                <Button Content="💎  Inventory"
                        Style="{Binding InventoryNavStyle, Mode=OneWay}"
                        Command="{Binding ShowInventoryCommand}" />
                <Button Content="📦  Purchases"
                        Style="{Binding PurchasesNavStyle, Mode=OneWay}"
                        Command="{Binding ShowPurchasesCommand}" />
                <Button Content="⚙️  Settings"
                        Style="{Binding SettingsNavStyle, Mode=OneWay}"
                        Command="{Binding ShowSettingsCommand}" />
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══════════════════════════════════════════ -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentView}" />
    </Grid>
</Window>
