<UserControl x:Class="InventoryApp.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f5f5f5">
    <Grid>
        <!-- Main content -->
        <TabControl Background="#f5f5f5" BorderThickness="0">
            <TabItem Header="📂  Categories" Foreground="#374151">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Category List -->
                    <Border Grid.Column="0" Background="#ffffff" CornerRadius="10" Margin="0,0,16,0" BorderBrush="#e5e7eb" BorderThickness="1">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Categories" FontSize="16" FontWeight="Bold"
                                       Foreground="#111827" Margin="16,16,16,8"/>
                            <Button DockPanel.Dock="Bottom" Content="+ New Category" Command="{Binding NewCategoryCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="12,8"/>
                            <ListBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}"
                                     Background="Transparent" BorderThickness="0" Foreground="#111827">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" Padding="8,4"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!-- Edit Panel -->
                    <Border Grid.Column="1" Background="#ffffff" CornerRadius="10" Padding="20" BorderBrush="#e5e7eb" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Category Details" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,16"/>
                            <Label Content="Category Name"/>
                            <TextBox Text="{Binding EditCategory.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                            <Label Content="Metal Type"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource MetalTypeValues}}"
                                      SelectedItem="{Binding EditCategory.MetalType}" Margin="0,0,0,20"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="💾 Save" Command="{Binding SaveCategoryCommand}" Style="{StaticResource PrimaryButton}" Width="100" Margin="0,0,10,0"/>
                                <Button Content="🗑 Delete" Command="{Binding DeleteCategoryCommand}" Style="{StaticResource DangerButton}" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="💎  Stock Items" Foreground="#374151">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Filter Bar -->
                    <Border Grid.Row="0" Background="#ffffff" CornerRadius="10" Padding="16" Margin="0,0,0,16" BorderBrush="#e5e7eb" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,12,0"
                                     Tag="🔍  Search by SKU or Name..." />
                            <ComboBox Grid.Column="1" ItemsSource="{Binding CategoriesForFilter}"
                                      SelectedItem="{Binding FilterCategory}"
                                      DisplayMemberPath="Name" Margin="0,0,12,0"/>
                            <ComboBox Grid.Column="2" ItemsSource="{Binding StatusFilters}"
                                      SelectedItem="{Binding FilterStatus}" Margin="0,0,12,0"/>
                            <Button Grid.Column="3" Content="➕ Add Item" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding OpenAddModalCommand}"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Items}" AutoGenerateColumns="False"
                              IsReadOnly="True" SelectedItem="{Binding SelectedItem}" SelectionMode="Single"
                              CanUserResizeRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SKU"         Binding="{Binding SKU}"          Width="120"/>
                            <DataGridTextColumn Header="Item Name"   Binding="{Binding Name}"         Width="*"/>
                            <DataGridTextColumn Header="Category"    Binding="{Binding CategoryName}" Width="120"/>
                            <DataGridTextColumn Header="Purity"      Binding="{Binding Purity}"       Width="90"/>
                            <DataGridTextColumn Header="Net Wt (g)"  Binding="{Binding NetWt, StringFormat={}{0:N2}}" Width="90"/>
                            <DataGridTextColumn Header="Cost ₹"      Binding="{Binding CostPrice, StringFormat={}₹{0:N0}}" Width="90"/>
                            <DataGridTextColumn Header="Status"
                                                Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="IsSold" Converter="{StaticResource BoolToStatus}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Actions" Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="🏷 Tag" Width="60" Margin="2"
                                                    Background="#1d4ed8" Foreground="White" BorderThickness="0"
                                                    Command="{Binding DataContext.PrintTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="✏" Width="32" Margin="2"
                                                    Background="#d97706" Foreground="White" BorderThickness="0"
                                                    Command="{Binding DataContext.OpenAddModalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="🗑" Width="32" Margin="2"
                                                    Background="#dc2626" Foreground="White" BorderThickness="0"
                                                    Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ── Add/Edit Item Modal Overlay ───────────────────────────── -->
        <Grid Visibility="{Binding IsAddModalOpen, Converter={StaticResource BoolToVisibility}}"
              xmlns:local="clr-namespace:InventoryApp">
            <Rectangle Fill="#88000000"/>
            <Border Background="#ffffff" CornerRadius="12" Padding="28" Width="480" VerticalAlignment="Center" BorderBrush="#e5e7eb" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Add / Edit Inventory Item" FontSize="18" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Item Name *"/>
                            <TextBox Text="{Binding FormItem.Name, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <Label Content="Category"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedValuePath="Id"
                                      SelectedValue="{Binding FormItem.CategoryId}" DisplayMemberPath="Name"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Gross Wt (g)"/>
                            <TextBox Text="{Binding FormItem.GrossWt, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,8,0">
                            <Label Content="Stone Wt (g)"/>
                            <TextBox Text="{Binding FormItem.StoneWt, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Label Content="Net Wt (g)"/>
                            <TextBox Text="{Binding FormItem.NetWt, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <Label Content="Purity"/>
                            <ComboBox ItemsSource="{Binding PurityOptions}" SelectedItem="{Binding FormItem.PurityStr}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Cost Price (₹)"/>
                            <TextBox Text="{Binding FormItem.CostPrice, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CloseModalCommand}" Width="90" Margin="0,0,10,0"
                                Background="#6b7280" Foreground="White" BorderThickness="0" Padding="0,8"/>
                        <Button Content="💾 Save &amp; Print Tag" Command="{Binding SaveItemCommand}"
                                Style="{StaticResource PrimaryButton}" Width="150"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
