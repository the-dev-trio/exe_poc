<UserControl x:Class="InventoryApp.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:InventoryApp"
             Background="{StaticResource AppBackgroundBrush}">

    <UserControl.Resources>
        <!-- Converter for Status Badge Coloring -->
        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSold}" Value="False">
                    <Setter Property="Background" Value="#dcfce7"/>
                    <Setter Property="TextElement.Foreground" Value="#166534"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSold}" Value="True">
                    <Setter Property="Background" Value="#fee2e2"/>
                    <Setter Property="TextElement.Foreground" Value="#991b1b"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ══ MAIN LAYOUT (Header + split view) ══ -->
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Inventory Management" FontSize="26" Style="{StaticResource HeadingText}" VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Manage Categories" Command="{Binding OpenCategoryModalCommand}"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,12,0" Padding="16,8"/>
                    <Button Content="+ New Item" Command="{Binding OpenAddModalCommand}"
                            Style="{StaticResource PrimaryButton}" Padding="16,8"/>
                </StackPanel>
            </Grid>

            <!-- Split View Area -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/> <!-- Sidebar -->
                    <ColumnDefinition Width="20"/>  <!-- Gutter -->
                    <ColumnDefinition Width="*"/>   <!-- Main Stock Table -->
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar: Categories -->
                <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="0,10">
                    <ListBox ItemsSource="{Binding CategoriesForFilter}" 
                             SelectedItem="{Binding SelectedCategory}"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="16,12"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#f1f5f9"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#f8fafc"/>
                                                    <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="TextElement.FontWeight" Value="SemiBold"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#f1f5f9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#e2e8f0" CornerRadius="10" Padding="8,2" MinWidth="26">
                                        <TextBlock Text="{Binding ItemCount}" FontSize="11" Foreground="#475569" HorizontalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- Main Area: Stock Items -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="0">
                    <DockPanel>
                        <!-- Top filter/search bar -->
                        <Border DockPanel.Dock="Top" BorderThickness="0,0,0,1" BorderBrush="#e2e8f0" Padding="16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Background="#f8fafc" BorderBrush="#cbd5e1" BorderThickness="1" CornerRadius="6" HorizontalAlignment="Left" Width="300">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔍" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="#64748b"/>
                                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="Transparent" BorderThickness="0" Width="260" Padding="4,8"
                                                 Tag="Search SKU or Name..."/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="Status:" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,8,0"/>
                                    <ComboBox ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding FilterStatus}" Width="120"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Count summary -->
                        <Border DockPanel.Dock="Top" Padding="16,10" Background="#fafafa">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding VisibleItemsCount, StringFormat={}Showing {0} items}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- DataGrid -->
                        <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" 
                                  SelectedItem="{Binding SelectedItem}" SelectionMode="Single"
                                  CanUserResizeRows="False" RowHeight="45"
                                  BorderThickness="0" Background="White"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#f1f5f9"
                                  HeadersVisibility="Column">
                            
                            <!-- Custom Navy Blue Headers -->
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,12"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU"         Binding="{Binding SKU}"          Width="110"/>
                                <DataGridTextColumn Header="Item Name"   Binding="{Binding Name}"         Width="*"/>
                                <DataGridTextColumn Header="Purity"      Binding="{Binding Purity}"       Width="90"/>
                                <DataGridTextColumn Header="Net Wt (g)"  Binding="{Binding NetWt, StringFormat={}{0:N2}}" Width="100"/>
                                <DataGridTextColumn Header="Cost (₹)"    Binding="{Binding CostPrice, StringFormat={}{0:N0}}" Width="90"/>
                                
                                <!-- Status Badge Column -->
                                <DataGridTemplateColumn Header="Status" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource StatusBadgeStyle}">
                                                <TextBlock Text="{Binding IsSold, Converter={StaticResource BoolToStatus}}" FontSize="11" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Actions Column -->
                                <DataGridTemplateColumn Header="Actions" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="🏷️" ToolTip="Print Tag" Width="32" Height="32" Margin="0,0,6,0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14"
                                                        Command="{Binding DataContext.PrintTagCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="✏️" ToolTip="Edit" Width="32" Height="32" Margin="0,0,6,0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14"
                                                        Command="{Binding DataContext.OpenAddModalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="🗑️" ToolTip="Delete" Width="32" Height="32" Margin="0"
                                                        Background="Transparent" BorderThickness="0" Cursor="Hand" FontSize="14"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ══ MODALS ══ -->
        <Grid>
            <!-- Dimmed Background for Modals -->
            <Rectangle Fill="#A0000000">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCategoryModalOpen}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                            <DataTrigger Binding="{Binding IsAddModalOpen}"      Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- 1. Category Management Modal -->
            <Border Width="500" Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28"
                    Visibility="{Binding IsCategoryModalOpen, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,16">
                        <TextBlock Text="Manage Categories" FontSize="20" Style="{StaticResource HeadingText}"/>
                        <Button Content="✕" Command="{Binding CloseCategoryModalCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#94a3b8" Cursor="Hand"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Category Name" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding EditCategory.Name, UpdateSourceTrigger=PropertyChanged}" Padding="8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Metal Type" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Source={StaticResource MetalTypeValues}}" SelectedItem="{Binding EditCategory.MetalType}" Padding="8"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,24">
                        <Button Content="Clear" Command="{Binding NewCategoryCommand}" Style="{StaticResource SecondaryButton}" Width="80" Margin="0,0,10,0"/>
                        <Button Content="Save Category" Command="{Binding SaveCategoryCommand}" Style="{StaticResource PrimaryButton}" Width="130"/>
                    </StackPanel>

                    <TextBlock Text="Existing Categories" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <DataGrid ItemsSource="{Binding Categories}" AutoGenerateColumns="False" IsReadOnly="True" SelectedItem="{Binding EditCategory}"
                              MaxHeight="200" BorderThickness="1" BorderBrush="#e2e8f0" HeadersVisibility="None" RowHeight="36">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Binding="{Binding MetalType}" Width="100"/>
                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑️" Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                Command="{Binding DataContext.DeleteCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- 2. Add/Edit Item Modal -->
            <Border Width="560" Background="White" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="32"
                    Visibility="{Binding IsAddModalOpen, Converter={StaticResource BoolToVisibility}}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="10" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Inventory Item Details" FontSize="20" Style="{StaticResource HeadingText}"/>
                        <Button Content="✕" Command="{Binding CloseModalCommand}" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" FontSize="16" Foreground="#94a3b8" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="Fill out the item details. SKU is generated automatically upon saving." FontSize="13" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,24"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Item Name *" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormItem.Name, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Category" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedValuePath="Id" SelectedValue="{Binding FormItem.CategoryId}" DisplayMemberPath="Name" Padding="10,8"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Gross Weight (g)" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormItem.GrossWt, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" ToolTip="Uses 4 decimal precision"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                            <TextBlock Text="Stone Weight (g)" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormItem.StoneWt, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" ToolTip="Uses 4 decimal precision"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                            <TextBlock Text="Net Weight (g)" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormItem.NetWt, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" ToolTip="Uses 4 decimal precision"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Purity" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding PurityOptions}" SelectedItem="{Binding FormItem.PurityStr}" Padding="10,8"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Cost Price (₹)" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FormItem.CostPrice, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Command="{Binding CloseModalCommand}" Width="100" Margin="0,0,12,0" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Save &amp; Label Tag" Command="{Binding SaveItemCommand}" Style="{StaticResource PrimaryButton}" Width="160" Padding="0,10"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
