<UserControl x:Class="InventoryApp.DailyRatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:InventoryApp.ViewModels"
             Background="{StaticResource AppBackgroundBrush}"
             FontFamily="{StaticResource BodyFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="24,20,24,24" MaxWidth="640">

            <!-- Page Title -->
            <TextBlock Text="Daily Metal Rates" FontSize="26" Style="{StaticResource HeadingText}" Margin="0,0,0,4"/>
            <TextBlock Text="Set today's rates per gram. These are used for all POS pricing and stock valuation."
                       Foreground="{StaticResource MutedTextBrush}" FontSize="13" Margin="0,0,0,20"/>

            <!-- Last Updated badge -->
            <Border Background="#f0f9ff" BorderBrush="#bae6fd" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="ℹ️" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding LastUpdated}" FontSize="13" Foreground="#0369a1" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- ═══ Gold Rates Card ════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🥇" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Gold Rates" FontSize="18" Style="{StaticResource HeadingText}"/>
                            <TextBlock Text="Price per gram (₹)" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- 24K -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Gold 24K (Pure)" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Text="999.9 fineness" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                        </StackPanel>
                        <Grid Grid.Column="1" Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#f3f4f6" CornerRadius="8,0,0,8" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,0,1">
                                <TextBlock Text="₹" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox Grid.Column="1" Text="{Binding Gold24K, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" FontWeight="SemiBold"
                                     VerticalContentAlignment="Center" Padding="8,6"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="/gram" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 22K -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Gold 22K (Hallmark)" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Text="{Binding Gold22KAuto}" FontSize="11" Foreground="#d97706"/>
                        </StackPanel>
                        <Grid Grid.Column="1" Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#f3f4f6" CornerRadius="8,0,0,8" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,0,1">
                                <TextBlock Text="₹" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox Grid.Column="1" Text="{Binding Gold22K, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" FontWeight="SemiBold"
                                     VerticalContentAlignment="Center" Padding="8,6"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="/gram" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 18K -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Gold 18K" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Text="{Binding Gold18KAuto}" FontSize="11" Foreground="#d97706"/>
                        </StackPanel>
                        <Grid Grid.Column="1" Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#f3f4f6" CornerRadius="8,0,0,8" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,0,1">
                                <TextBlock Text="₹" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                            </Border>
                            <TextBox Grid.Column="1" Text="{Binding Gold18K, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="14" FontWeight="SemiBold"
                                     VerticalContentAlignment="Center" Padding="8,6"/>
                        </Grid>
                        <TextBlock Grid.Column="2" Text="/gram" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ═══ Silver Rate Card ════════════════════════════════════ -->
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="🥈" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Silver" FontSize="18" Style="{StaticResource HeadingText}"/>
                            <TextBlock Text="Price per gram (₹)" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock Text="Silver (999)" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                        <TextBlock Text="Fine silver" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                    <Grid Grid.Column="3" Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#f3f4f6" CornerRadius="8,0,0,8" Padding="10,6" BorderBrush="#e2e8f0" BorderThickness="1,1,0,1">
                            <TextBlock Text="₹" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding Silver, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="14" FontWeight="SemiBold"
                                 VerticalContentAlignment="Center" Padding="8,6"/>
                    </Grid>
                    <TextBlock Grid.Column="4" Text="/gram" FontSize="12" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Save Button -->
            <Button Content="💾  Save Metal Rates" Command="{Binding SaveRatesCommand}"
                    Style="{StaticResource PrimaryButton}"
                    FontSize="15" Padding="28,12" HorizontalAlignment="Left"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
