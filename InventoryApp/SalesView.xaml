<UserControl x:Class="InventoryApp.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:InventoryApp"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Cart ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="POS / Sales" FontSize="22" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>

            <!-- Scan input -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="16" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="140"/><ColumnDefinition Width="140"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ScanInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="18" Padding="10,8" Margin="0,0,8,0"
                             local:FocusBehavior.IsFocused="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="Scan / Add" Command="{Binding ScanCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="2" Margin="0,0,8,0">
                        <Label Content="Making Charge (₹)" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Padding="0,2,0,2"/>
                        <TextBox Text="{Binding MakingCharge, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <Label Content="Discount (₹)" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Padding="0,2,0,2"/>
                        <TextBox Text="{Binding DiscountAmount, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cart DataGrid -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU"    Binding="{Binding SKU}"    Width="110"/>
                    <DataGridTextColumn Header="Item"   Binding="{Binding Name}"   Width="*"/>
                    <DataGridTextColumn Header="Wt(g)"  Binding="{Binding NetWt, StringFormat={}{0:N2}}" Width="70"/>
                    <DataGridTextColumn Header="Rate"   Binding="{Binding Rate, StringFormat={}₹{0:N0}}"  Width="80"/>
                    <DataGridTextColumn Header="Making" Binding="{Binding MakingCharge, StringFormat={}₹{0:N0}}" Width="80"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding FinalAmount, StringFormat={}₹{0:N0}}" Width="90"/>
                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove" Width="60" Style="{StaticResource DangerButtonSmall}"
                                        Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Totals + Status -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="16" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Subtotal,       StringFormat={}Subtotal:  ₹{0:N2}}" Foreground="{StaticResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding DiscountAmount, StringFormat={}Discount: -₹{0:N2}}" Foreground="#dc2626"
                                   Visibility="{Binding DiscountAmount, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding Cgst,           StringFormat={}CGST:      ₹{0:N2}}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding Sgst,           StringFormat={}SGST:      ₹{0:N2}}" Foreground="{StaticResource MutedTextBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding GrandTotal,     StringFormat={}TOTAL:     ₹{0:N2}}"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ RIGHT: Customer + Payment ═══════════════════════════ -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Padding="20">
            <StackPanel>
                <TextBlock Text="Customer" FontSize="16" Style="{StaticResource HeadingText}" Margin="0,0,0,12"/>
                <Label Content="Search (Name / Mobile)"/>
                <TextBox Text="{Binding CustomerSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <!-- Suggestions -->
                <ListBox ItemsSource="{Binding CustomerSuggestions}"
                         Visibility="{Binding CustomerSuggestions.Count, Converter={StaticResource BoolToVisibility}}"
                         Background="#ffffff" Foreground="#111827" MaxHeight="120" Margin="0,0,0,8" BorderBrush="#e2e8f0" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </TextBlock.InputBindings>
                                <Run Text="{Binding Name}"/> — <Run Text="{Binding Mobile}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Label Content="Customer Name"/>
                <TextBox Text="{Binding CurrentCustomer.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <Label Content="Mobile"/>
                <TextBox Text="{Binding CurrentCustomer.Mobile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <Separator Background="#e2e8f0" Margin="0,0,0,16"/>

                <TextBlock Text="Payment Mode" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding PaymentModes}" SelectedItem="{Binding SelectedPaymentMode}"
                         Background="Transparent" Foreground="#111827" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Separator Background="#e2e8f0" Margin="0,16"/>

                <Button Content="Complete Sale" Command="{Binding CompleteSaleCommand}"
                        Style="{StaticResource PrimaryButton}" Height="52" FontSize="16" Margin="0,0,0,8"/>
                <Button Content="Clear Cart" Command="{Binding ClearCartCommand}"
                        Style="{StaticResource SecondaryButton}" Padding="0,10" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
