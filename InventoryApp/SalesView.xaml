<UserControl x:Class="InventoryApp.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:InventoryApp"
             Background="#f5f5f5">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══ LEFT: Cart ══════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🛒  POS / Sales" FontSize="22" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>

            <!-- Scan input -->
            <Border Grid.Row="1" Background="#ffffff" CornerRadius="10" Padding="16" Margin="0,0,0,12" BorderBrush="#e5e7eb" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="150"/></Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding ScanInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="18" Padding="10,8" Margin="0,0,8,0"
                             local:FocusBehavior.IsFocused="True">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding ScanCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="Scan / Add" Command="{Binding ScanCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="2">
                        <Label Content="Making Charge ₹" FontSize="11"/>
                        <TextBox Text="{Binding MakingCharge, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cart DataGrid -->
            <DataGrid Grid.Row="2" ItemsSource="{Binding Cart}" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserResizeRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="SKU"    Binding="{Binding SKU}"    Width="110"/>
                    <DataGridTextColumn Header="Item"   Binding="{Binding Name}"   Width="*"/>
                    <DataGridTextColumn Header="Wt(g)"  Binding="{Binding NetWt, StringFormat={}{0:N2}}" Width="70"/>
                    <DataGridTextColumn Header="Rate"   Binding="{Binding Rate, StringFormat={}₹{0:N0}}"  Width="80"/>
                    <DataGridTextColumn Header="Making" Binding="{Binding MakingCharge, StringFormat={}₹{0:N0}}" Width="80"/>
                    <DataGridTextColumn Header="Amount" Binding="{Binding FinalAmount, StringFormat={}₹{0:N0}}" Width="90"/>
                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Background="#dc2626" Foreground="White" BorderThickness="0" Width="26"
                                        Command="{Binding DataContext.RemoveCartItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Totals + Status -->
            <Border Grid.Row="3" Background="#ffffff" CornerRadius="10" Padding="16" Margin="0,12,0,0" BorderBrush="#e5e7eb" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#6b7280" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding Subtotal,  StringFormat={}Subtotal: ₹{0:N2}}"  Foreground="#374151"/>
                        <TextBlock Text="{Binding GstAmount, StringFormat={}GST (3%): ₹{0:N2}}"  Foreground="#374151"/>
                        <TextBlock Text="{Binding GrandTotal,StringFormat={}TOTAL:    ₹{0:N2}}"
                                   FontSize="20" FontWeight="Bold" Foreground="#15803d"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ RIGHT: Customer + Payment ═══════════════════════════ -->
        <Border Grid.Column="1" Background="#ffffff" CornerRadius="10" Padding="20" BorderBrush="#e5e7eb" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Customer" FontSize="16" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,12"/>
                <Label Content="Search (Name / Mobile)"/>
                <TextBox Text="{Binding CustomerSearch, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,4"/>
                <!-- Suggestions -->
                <ListBox ItemsSource="{Binding CustomerSuggestions}"
                         Visibility="{Binding CustomerSuggestions.Count, Converter={StaticResource BoolToVisibility}}"
                         Background="#ffffff" Foreground="#111827" MaxHeight="120" Margin="0,0,0,8" BorderBrush="#e5e7eb" BorderThickness="1">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </TextBlock.InputBindings>
                                <Run Text="{Binding Name}"/> — <Run Text="{Binding Mobile}"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Label Content="Customer Name"/>
                <TextBox Text="{Binding CurrentCustomer.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                <Label Content="Mobile"/>
                <TextBox Text="{Binding CurrentCustomer.Mobile, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                <Separator Background="#e5e7eb" Margin="0,0,0,16"/>

                <TextBlock Text="Payment Mode" FontSize="14" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding PaymentModes}" SelectedItem="{Binding SelectedPaymentMode}"
                         Background="Transparent" Foreground="#111827" BorderThickness="0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Separator Background="#e5e7eb" Margin="0,16"/>

                <Button Content="✅  Complete Sale" Command="{Binding CompleteSaleCommand}"
                        Style="{StaticResource SuccessButton}" Height="52" FontSize="16" Margin="0,0,0,8"/>
                <Button Content="🗑  Clear Cart" Command="{Binding ClearCartCommand}"
                        Background="#6b7280" Foreground="White" BorderThickness="0" Padding="0,10" FontSize="13"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
