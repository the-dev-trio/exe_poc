<UserControl x:Class="InventoryApp.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <StackPanel Margin="24">

            <!-- Title -->
            <TextBlock Text="Dashboard" FontSize="26" Style="{StaticResource HeadingText}" Margin="0,0,0,20"/>

            <!-- ── Metal Rates Input ─────────────────────────────────── -->
            <TextBlock Text="TODAY'S METAL RATES" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Label Content="Gold 24K (₹/gram)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox Text="{Binding Rates.Gold24K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <Label Content="Gold 22K (₹/gram)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox Text="{Binding Rates.Gold22K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <Label Content="Gold 18K (₹/gram)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox Text="{Binding Rates.Gold18K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <Label Content="Silver (₹/gram)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox Text="{Binding Rates.Silver, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="4" Content="Update Rates" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateRatesCommand}" VerticalAlignment="Bottom" />
                </Grid>
            </Border>

            <!-- ── Asset Summary Cards ──────────────────────────────── -->
            <TextBlock Text="ASSET SUMMARY" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <!-- Total Stock -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="📦  Total Stock" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0} Pcs}"
                                   FontSize="36" FontWeight="Bold" Foreground="{StaticResource SidebarBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="items in stock" Foreground="#6b7280" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Total Weight -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="⚖️  Total Weight" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding GoldWeight, StringFormat={}Gold: {0:N2}g}"
                                   FontSize="22" FontWeight="Bold" Foreground="{StaticResource GoldBrush}" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SilverWeight, StringFormat={}Silver: {0:N2}g}"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#64748b"/>
                    </StackPanel>
                </Border>

                <!-- Total Asset Value -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="💰  Total Asset Value" Foreground="{StaticResource MutedTextBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding TotalValue, StringFormat={}₹{0:N0}}"
                                   FontSize="30" FontWeight="Bold" Foreground="{StaticResource GoldBrush}" Margin="0,8,0,0"/>
                        <TextBlock Text="at today's rates" Foreground="#6b7280" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Quick Actions ─────────────────────────────────────── -->
            <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="New Sale" Style="{StaticResource PrimaryButton}" Width="160" Height="50" Margin="0,0,12,0" FontSize="15"/>
                <Button Content="Add Stock" Style="{StaticResource SecondaryButton}" Width="160" Height="50" FontSize="15"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
