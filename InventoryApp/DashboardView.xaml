<UserControl x:Class="InventoryApp.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#f5f5f5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Title -->
            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,20"/>

            <!-- ── Metal Rates Input ─────────────────────────────────── -->
            <TextBlock Text="TODAY'S METAL RATES" FontSize="11" Foreground="#4b5563" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Border Background="#ffffff" CornerRadius="10" Padding="20" Margin="0,0,0,24" BorderBrush="#e5e7eb" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <Label Content="Gold 24K (₹/gram)" Foreground="#374151"/>
                        <TextBox Text="{Binding Rates.Gold24K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <Label Content="Gold 22K (₹/gram)" Foreground="#374151"/>
                        <TextBox Text="{Binding Rates.Gold22K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,12,0">
                        <Label Content="Gold 18K (₹/gram)" Foreground="#374151"/>
                        <TextBox Text="{Binding Rates.Gold18K, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,12,0">
                        <Label Content="Silver (₹/gram)" Foreground="#374151"/>
                        <TextBox Text="{Binding Rates.Silver, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Button Grid.Column="4" Content="Update Rates" Style="{StaticResource PrimaryButton}"
                            Command="{Binding UpdateRatesCommand}" VerticalAlignment="Bottom" />
                </Grid>
            </Border>

            <!-- ── Asset Summary Cards ──────────────────────────────── -->
            <TextBlock Text="ASSET SUMMARY" FontSize="11" Foreground="#4b5563" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <UniformGrid Columns="3" Margin="0,0,0,24">
                <!-- Total Stock -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="📦  Total Stock" Foreground="#374151" FontSize="13"/>
                        <TextBlock Text="{Binding TotalCount, StringFormat={}{0:N0} Pcs}"
                                   FontSize="36" FontWeight="Bold" Foreground="#111827" Margin="0,8,0,0"/>
                        <TextBlock Text="items in stock" Foreground="#6b7280" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Total Weight -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="⚖️  Total Weight" Foreground="#374151" FontSize="13"/>
                        <TextBlock Text="{Binding GoldWeight, StringFormat={}Gold: {0:N2}g}"
                                   FontSize="22" FontWeight="Bold" Foreground="#b45309" Margin="0,8,0,2"/>
                        <TextBlock Text="{Binding SilverWeight, StringFormat={}Silver: {0:N2}g}"
                                   FontSize="18" FontWeight="SemiBold" Foreground="#475569"/>
                    </StackPanel>
                </Border>

                <!-- Total Asset Value -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="💰  Total Asset Value" Foreground="#374151" FontSize="13"/>
                        <TextBlock Text="{Binding TotalValue, StringFormat={}₹{0:N0}}"
                                   FontSize="30" FontWeight="Bold" Foreground="#15803d" Margin="0,8,0,0"/>
                        <TextBlock Text="at today's rates" Foreground="#6b7280" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ── Quick Actions ─────────────────────────────────────── -->
            <TextBlock Text="QUICK ACTIONS" FontSize="11" Foreground="#4b5563" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <Button Content="🛒  New Sale" Style="{StaticResource SuccessButton}" Width="160" Height="50" Margin="0,0,12,0" FontSize="15"/>
                <Button Content="➕  Add Stock" Style="{StaticResource PrimaryButton}" Width="160" Height="50" FontSize="15"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
