<UserControl x:Class="InventoryApp.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <StackPanel Margin="24" MaxWidth="720">
            <TextBlock Text="Settings" FontSize="24" Style="{StaticResource HeadingText}" Margin="0,0,0,24"/>

            <!-- Business Info -->
            <TextBlock Text="BUSINESS INFO" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <StackPanel>
                    <Label Content="Shop Name"/>
                    <TextBox Text="{Binding ShopName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    <Label Content="Address / Phone"/>
                    <TextBox Text="{Binding ShopAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    <Label Content="GST / Tax Number"/>
                    <TextBox Text="{Binding GSTNumber, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Border>

            <!-- Label Printer -->
            <TextBlock Text="LABEL PRINTER (ZEBRA / TSC)" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Label Content="Select Printer"/>
                        <ComboBox ItemsSource="{Binding InstalledPrinters}" SelectedItem="{Binding LabelPrinter}"/>
                        <Label Content="Label Size: 50mm × 25mm  (ZPL format)" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Test Print" Command="{Binding TestLabelPrinterCommand}"
                            Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Receipt Printer -->
            <TextBlock Text="RECEIPT PRINTER (BILLING)" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <Label Content="Select Printer"/>
                        <ComboBox ItemsSource="{Binding InstalledPrinters}" SelectedItem="{Binding ReceiptPrinter}"/>
                        <CheckBox Content="Enable Silent Printing (no dialog)" IsChecked="True" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="Test Print" Command="{Binding TestReceiptPrinterCommand}"
                            Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Backup -->
            <TextBlock Text="BACKUP" Style="{StaticResource SectionLabelText}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,24">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BackupPath}" IsReadOnly="True" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Browse" Command="{Binding BrowseBackupPathCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Grid.Column="2" Content="Backup Now" Command="{Binding BackupNowCommand}"
                                Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                    <TextBlock Text="Tip: choose a local folder or a synced drive (e.g., Google Drive)."
                               Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,6,0,0"/>
                    <CheckBox Content="Auto-backup database when application closes"
                              IsChecked="{Binding AutoBackup}" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

            <!-- Save -->
            <Button Content="Save All Settings" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}" Width="220" Height="44" FontSize="15" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</UserControl>
